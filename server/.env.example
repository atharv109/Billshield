# Copy this file to server/.env and fill in your values.
# server/.env is gitignored — never commit real keys.

# Required for Claude agents. Without this, all agents fall back to
# deterministic rules only (still produces a usable result, but with
# lower confidence and no LLM-generated summaries or actions).
ANTHROPIC_API_KEY=sk-ant-...

# Override the default listen port (default: 3001).
# PORT=3001
