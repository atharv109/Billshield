# Copy this file to server/.env and fill in your values.
# server/.env is gitignored — never commit real keys.

# ── High-risk agents (docType, billExtraction, eobExtraction, comparison) ──────
# Primary provider. Without this, all agents fall back to deterministic rules only
# (still produces a usable result, but with lower confidence).
ANTHROPIC_API_KEY=sk-ant-...

# Fallback provider for high-risk agents (used if Anthropic fails or is unavailable).
# Without this, the fallback chain skips straight to deterministic-only output.
OPENAI_API_KEY=sk-...

# ── Low-risk agents (summary, action) ──────────────────────────────────────────
# MiroFish: cheap/free primary for summary and action wording.
# All three vars are required for MiroFish to initialise. Omit to skip this provider.
MIROFISH_API_KEY=
MIROFISH_BASE_URL=https://api.mirofish.ai/v1
# MIROFISH_MODEL=mirofish-default

# Gemini: mid-tier cheap fallback between MiroFish and paid Anthropic.
# Omit to skip this provider.
GEMINI_API_KEY=

# ── Server config ───────────────────────────────────────────────────────────────
# Override the default listen port (default: 3001).
# PORT=3001

# Allowed browser origins for CORS (comma-separated). Omit to use localhost:5173
# and 127.0.0.1:5173 only.
# CORS_ORIGIN=http://localhost:5173,https://app.example.com
