# Copy to .env and load with your tooling, or export manually.
# SQLite database file (default: ./data/billshield.db)
# BILLSHIELD_DB=C:\path\to\billshield.db

# Demo JSON for ?demo=true routes (default: ./cache/demo_responses.json)
# BILLSHIELD_DEMO_CACHE=C:\path\to\demo_responses.json

# HTTP port when using: python main.py
# PORT=8000

# Hot reload for python main.py (1=yes, 0=no)
# BILLSHIELD_RELOAD=1
